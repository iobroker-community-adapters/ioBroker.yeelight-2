{
    "type": "panel",
    "i18n": true,
    "items": {
        "_find": {
            "type": "sendTo",
            "command": "discovery",
            "data": { "turnon": 1 },
            "label": "Find Devices",
            "useNative": true,
            "showProcess": true,
            "icon": "search",
            "xs": 12,
            "sm": 6,
            "md": 4,
            "lg": 3,
            "xl": 2
        },
        "devices": {
            "type": "table",
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "items": [
                {
                    "type": "text",
                    "attr": "name",
                    "title": "Name",
                    "width": "25%"
                },
                {
                    "type": "text",
                    "attr": "ip",
                    "title": "ip adress",
                    "width": "20%"
                },
                {
                    "type": "number",
                    "attr": "port",
                    "title": "port",
                    "width": "10%",
                    "default": 55443
                },
                {
                    "type": "text",
                    "attr": "smart_name",
                    "title": "smartname",
                    "width": "20%",
                    "default": ""
                },
                {
                    "type": "select",
                    "attr": "type",
                    "title": "type",
                    "width": "25%",
                    "options": [
                        { "label": "color", "value": "color" },
                        { "label": "ceiling1", "value": "ceiling1" },
                        { "label": "ceiling2", "value": "ceiling2" },
                        { "label": "ceiling3 / yeelight480", "value": "ceiling3" },
                        { "label": "ceiling4 / yeelight650", "value": "ceiling4" },
                        { "label": "ceiling10 / pendant", "value": "ceiling10" },
                        { "label": "bslamp1", "value": "bslamp1" },
                        { "label": "desklamp", "value": "desklamp" },
                        { "label": "mono", "value": "mono" },
                        { "label": "stripe", "value": "stripe" }
                    ]
                }
            ]
        }
    }
}
